rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /images/{category}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /videos/{category}/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
